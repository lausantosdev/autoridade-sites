# ── IA ────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...                    # Supabase > Settings > API > anon public
SUPABASE_SERVICE_KEY=eyJ...                 # Supabase > Settings > API > service_role
SUPABASE_JWT_SECRET=your-jwt-secret-here    # Supabase > Settings > API > JWT Secret

# ── Cloudflare ────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here
CLOUDFLARE_PAGES_PROJECT=autoridade-digital  # nome do projeto Pages (criado manualmente)
WORKER_URL=https://seu-worker.workers.dev    # URL do Cloudflare Worker de leads

# ── Servidor ──────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=production  # production | development
